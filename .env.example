# Backend / Express Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
# Replace these with actual values if you start using real Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend Configuration
VITE_API_URL=http://localhost:3000

# FPT AI Marketplace / Gemma model gateway
# Keep this server-side only. Never expose it with a VITE_ prefix.
FPT_API_KEY=your-fpt-ai-marketplace-api-key
FPT_BASE_URL=https://mkp-api.fptcloud.com
FPT_MODEL=gemma-3-27b-it
MODEL_GATEWAY_ENABLED=true
